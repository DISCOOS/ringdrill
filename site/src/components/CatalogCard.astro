---
import { t, type Lang } from '../i18n';
import type { CatalogItem } from '../lib/catalog';

interface Props {
  item: CatalogItem;
  lang: Lang;
}

const { item, lang } = Astro.props;
const c = t(lang);

// The front door for "get this plan" is the human preview page (ADR-0015/
// ADR-0044), never the feed's raw latestUrl (a .drill binary download).
const previewUrl = `/i/${item.slug}?lang=${lang}`;

// Same target drills-preview.js's own primary "Open the plan" button uses
// (ADR-0015): a path-based share link that installs/activates the plan
// straight in the PWA, bypassing the preview page.
const openWebUrl = `https://web.ringdrill.app/i/${item.slug}`;
const exerciseLabel =
  item.exerciseCount == null
    ? null
    : `${item.exerciseCount} ${item.exerciseCount === 1 ? c.catalog.exerciseUnit : c.catalog.exercisePlural}`;
// Includes time (not just date) per request — a plan republished several
// times in one day previously looked identical in the card.
const updatedLabel = item.updatedAt
  ? new Date(item.updatedAt).toLocaleString(lang === 'nb' ? 'nb-NO' : 'en-US', {
      day: 'numeric',
      month: 'short',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    })
  : null;

const shareUrl = new URL(previewUrl, Astro.site ?? 'https://ringdrill.app').toString();
---
<li class="catalog-card" data-language={item.languageCode ?? ''}>
  <h3><a href={previewUrl}>{item.name}</a></h3>
  {item.description && <p class="catalog-card__desc">{item.description}</p>}
  {(item.tags.length > 0 || item.place) && (
    <ul class="catalog-card__tags">
      {item.tags.map((tag) => <li>{tag}</li>)}
      {item.place && <li class="catalog-card__tags-place">{item.place}</li>}
    </ul>
  )}
  {(item.mapBounds || item.mapCenter) && (
    <div
      class="catalog-card__map"
      data-lat={item.mapCenter?.lat}
      data-lng={item.mapCenter?.lng}
      data-north={item.mapBounds?.north}
      data-south={item.mapBounds?.south}
      data-east={item.mapBounds?.east}
      data-west={item.mapBounds?.west}
    />
  )}
  {(exerciseLabel || updatedLabel) && (
    <p class="catalog-card__meta">
      {exerciseLabel && <span>{exerciseLabel}</span>}
      {exerciseLabel && updatedLabel && <span class="sep" aria-hidden="true">·</span>}
      {updatedLabel && (
        <span>{c.catalog.updated} <time datetime={item.updatedAt ?? undefined}>{updatedLabel}</time></span>
      )}
    </p>
  )}
  <div class="catalog-card__actions">
    <a class="btn btn--primary btn--sm" href={previewUrl}>{c.catalog.download}</a>
    <a class="btn btn--ghost btn--sm" href={openWebUrl}>{c.nav.openWeb}</a>
    <button
      type="button"
      class="catalog-card__share"
      data-share-url={shareUrl}
      data-share-title={item.name}
      aria-label={c.catalog.share}
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 3v12" />
        <path d="M7.5 7.5 12 3l4.5 4.5" />
        <path d="M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-7" />
      </svg>
    </button>
  </div>
</li>

<style>
  .catalog-card {
    background: var(--canvas-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 24px;
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease;
    /* .catalog__grid is a CSS multi-column layout (masonry-style), not a
       grid — column-gap only spaces columns apart, not stacked items
       within one, so vertical spacing between cards is a margin here.
       break-inside keeps a card (and its map) from splitting across the
       column break. */
    break-inside: avoid;
    margin-bottom: 24px;
  }
  .catalog-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lift);
  }
  .catalog-card h3 { margin: 0; }
  .catalog-card h3 a { color: var(--heading); text-decoration: none; }
  .catalog-card h3 a:hover { color: var(--link); }
  .catalog-card__desc {
    color: var(--body);
    font-size: 0.9375rem;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  /* Matches the .tags/.tags li chip styling in drills-preview.js's rendered
     /i/<slug> page — same pill shape, weight and chip-tinted color, so a
     tag reads the same wherever it's shown. */
  .catalog-card__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0;
    padding: 0;
  }
  .catalog-card__tags li {
    background: var(--chip-bg);
    color: var(--chip-ink);
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-pill);
  }
  /* Reverse-geocoded, not author-entered like the other tags — an outline
     instead of a filled chip marks it as "roughly here", not a curated
     label the plan owner picked. */
  .catalog-card__tags li.catalog-card__tags-place {
    background: transparent;
    border: 1px solid var(--border-strong);
    color: var(--muted);
    font-weight: 500;
  }
  .catalog-card__meta { color: var(--muted); font-size: 0.75rem; margin: 0; }
  .catalog-card__meta .sep { margin: 0 0.45rem; opacity: 0.6; }
  .catalog-card__map {
    height: 220px;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--canvas-band);
  }
  .catalog-card__actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    /* Pushes the action row to the bottom of its own card regardless of
       how much content (description length, tag count, map) precedes it.
       The catalog grid is a masonry-style multi-column layout now (see
       catalog.astro), so this no longer lines actions up across cards in
       a row — it just keeps each card's own buttons flush to its bottom
       edge. */
    margin-top: auto;
    padding-top: 4px;
  }
  .catalog-card__share {
    position: relative;
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    background: transparent;
    color: var(--heading);
    cursor: pointer;
    transition: background 0.16s ease, border-color 0.16s ease;
  }
  .catalog-card__share:hover { background: var(--canvas-band); border-color: var(--teal); }
  .catalog-card__share svg { width: 18px; height: 18px; }
  /* Custom tooltip instead of relying on the native title attribute
     (slow to appear, unstyled, inconsistent across browsers) — an
     icon-only button needs a legible label on hover/focus, not just an
     aria-label a mouse user never sees. */
  .catalog-card__share::after {
    content: attr(aria-label);
    position: absolute;
    bottom: calc(100% + 8px);
    right: 0;
    background: var(--heading);
    color: var(--canvas);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1;
    white-space: nowrap;
    padding: 6px 10px;
    border-radius: var(--radius-sm);
    opacity: 0;
    transform: translateY(2px);
    pointer-events: none;
    transition: opacity 0.12s ease, transform 0.12s ease;
  }
  .catalog-card__share:hover::after,
  .catalog-card__share:focus-visible::after {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';

  // Same tile provider as the in-app map (lib/views/map_view.dart). The
  // "© Kartverket" / "© OpenStreetMap contributors" attribution this needs
  // is shown once for the whole page (see .catalog__map-attribution in
  // catalog.astro / en/catalog.astro), not per card — so each map's own
  // attribution control is disabled here rather than duplicating it on
  // every card.
  const KARTVERKET_TOPO_URL =
    'https://cache.kartverket.no/v1/wmts/1.0.0/topo/default/webmercator/{z}/{y}/{x}.png';

  // A degenerate box (a single station, or several stations at the exact
  // same spot) has zero width/height — pad it a little so Leaflet still
  // renders a visible rectangle instead of a zero-area line.
  const MIN_PAD_DEGREES = 0.01;

  const containers = document.querySelectorAll<HTMLElement>(
    '.catalog-card__map:not([data-mounted])',
  );

  for (const el of containers) {
    const north = Number(el.dataset.north);
    const south = Number(el.dataset.south);
    const east = Number(el.dataset.east);
    const west = Number(el.dataset.west);
    const hasBounds =
      Number.isFinite(north) && Number.isFinite(south) &&
      Number.isFinite(east) && Number.isFinite(west);

    const lat = Number(el.dataset.lat);
    const lng = Number(el.dataset.lng);
    const hasCenter = Number.isFinite(lat) && Number.isFinite(lng);

    if (!hasBounds && !hasCenter) continue;
    el.dataset.mounted = 'true';

    // Non-interactive: this shows the real extent of the plan's stations
    // (ADR-0040's bounding-box addendum), not a live map to pan/zoom.
    const map = L.map(el, {
      zoomControl: false,
      dragging: false,
      scrollWheelZoom: false,
      doubleClickZoom: false,
      attributionControl: false,
    });

    L.tileLayer(KARTVERKET_TOPO_URL, { maxZoom: 18 }).addTo(map);

    // The catalog grid is a CSS multi-column layout (masonry-style) — a
    // card's final width isn't always settled at the moment this script
    // runs, so Leaflet can read a stale/too-small container size and
    // compute a much-too-zoomed-out fit. invalidateSize() forces it to
    // re-measure the container right before fitBounds() uses it.
    map.invalidateSize();

    if (hasBounds) {
      const padded = L.latLngBounds(
        [south - MIN_PAD_DEGREES, west - MIN_PAD_DEGREES],
        [north + MIN_PAD_DEGREES, east + MIN_PAD_DEGREES],
      );
      L.rectangle([[south, west], [north, east]], {
        color: 'var(--teal, #0f766e)',
        weight: 2,
        fillOpacity: 0.12,
        interactive: false,
      }).addTo(map);
      map.fitBounds(padded, { maxZoom: 15 });
    } else {
      // Legacy blob published before the bounding-box addendum: only a
      // centroid is on file. Fall back to the old fixed-zoom dot view
      // rather than showing nothing until the plan is republished.
      map.setView([lat, lng], 12);
    }
  }

  // Share button: native share sheet where available (mobile Safari/Chrome,
  // macOS Safari), clipboard copy as the fallback everywhere else — with a
  // brief checkmark swap so a click always gives some visible feedback.
  const CHECK_ICON = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5L19 8" /></svg>`;

  const shareButtons = document.querySelectorAll<HTMLButtonElement>(
    '.catalog-card__share:not([data-share-bound])',
  );

  for (const button of shareButtons) {
    button.dataset.shareBound = 'true';
    button.addEventListener('click', async () => {
      const url = button.dataset.shareUrl;
      const title = button.dataset.shareTitle;
      if (!url) return;

      if (navigator.share) {
        try {
          await navigator.share({ title, url });
          return;
        } catch {
          // AbortError (user cancelled) or an unsupported share target —
          // fall through to the clipboard copy below rather than doing
          // nothing.
        }
      }

      try {
        await navigator.clipboard.writeText(url);
        const original = button.innerHTML;
        button.innerHTML = CHECK_ICON;
        setTimeout(() => { button.innerHTML = original; }, 1500);
      } catch {
        // Clipboard API unavailable (e.g. insecure context) — nothing more
        // to do.
      }
    });
  }
</script>
