---
// On-demand (ADR-0044 rendering pattern applied to ADR-0039's reserved
// /catalog route): fetched fresh per request, never build-time-static.
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import CatalogCard from '../../components/CatalogCard.astro';
import { fetchCatalog } from '../../lib/catalog';
import { distinctLanguageCodes, LANGUAGE_NAMES } from '../../lib/languages';
import { t } from '../../i18n';

const lang = 'en';
const c = t(lang);

const apiBase = import.meta.env.PUBLIC_RINGDRILL_API_BASE || 'https://api.ringdrill.app';
const result = await fetchCatalog({ apiBase });
const languageCodes = distinctLanguageCodes(result.items);

// Mirrors market-feed.js's own max-age=30 so Cloudflare's edge absorbs
// repeat traffic instead of re-fetching the feed on every visit.
Astro.response.headers.set('Cache-Control', 'public, max-age=30, s-maxage=60');
---
<BaseLayout lang="en" title={`${c.catalog.title} · RingDrill`} description={c.catalog.lead} canonicalPath="/en/catalog">
  <Nav lang="en" langHref="/catalog" />
  <main>
    <section class="section section--band">
      <div class="container">
        <div class="catalog__header">
          <div class="catalog__intro">
            <span class="eyebrow">{c.catalog.eyebrow}</span>
            <h1 class="catalog__title">{c.catalog.title}</h1>
            <p class="lead">{c.catalog.lead}</p>
          </div>
          {result.items.length > 0 && (
            <div class="catalog__toolbar">
              <input
                type="search"
                class="catalog__search"
                id="catalog-search"
                placeholder={c.catalog.searchPlaceholder}
                aria-label={c.catalog.searchPlaceholder}
              />
              {languageCodes.length > 1 && (
                <select
                  class="catalog__language-filter"
                  id="catalog-language-filter"
                  aria-label={c.catalog.languageFilterLabel}
                >
                  <option value="">{c.catalog.allLanguages}</option>
                  {languageCodes.map((code) => (
                    <option value={code}>{LANGUAGE_NAMES[code] ?? code}</option>
                  ))}
                </select>
              )}
            </div>
          )}
        </div>

        {result.items.length > 0 ? (
          <>
            <ul class="catalog__grid">
              {result.items.map((item) => <CatalogCard item={item} lang="en" />)}
            </ul>
            {result.items.some((item) => item.mapCenter || item.mapBounds) && (
              <p class="catalog__map-attribution">{c.catalog.mapAttribution}</p>
            )}
          </>
        ) : (
          <div class="catalog__empty prose">
            <p class="lead">{result.failed ? c.catalog.emptyUnavailable : c.catalog.emptyNoPlans}</p>
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer lang="en" langHref="/catalog" />
</BaseLayout>

<style>
  .catalog__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 20px 24px;
  }
  .catalog__intro { flex: 1 1 320px; }
  .catalog__title { margin-top: 12px; }
  .catalog__toolbar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    /* Roughly aligns with the title, not the eyebrow above it. */
    margin-top: 44px;
  }
  .catalog__search {
    font: inherit;
    font-size: 0.9375rem;
    color: var(--heading);
    background: var(--canvas-elev);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    padding: 6px 12px;
    min-width: 220px;
    flex: 1 1 220px;
  }
  .catalog__language-filter {
    font: inherit;
    font-size: 0.9375rem;
    color: var(--heading);
    background: var(--canvas-elev);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    padding: 6px 12px;
    flex: 0 0 auto;
  }
  @media (max-width: 720px) {
    .catalog__toolbar { width: 100%; margin-top: 20px; }
  }
  .catalog__grid {
    list-style: none;
    margin-top: 40px;
    /* Masonry-style: a CSS multi-column layout, not a grid. Cards flow
       top-to-bottom within a column before wrapping to the next one, so
       short cards (no map) stack together instead of each being stretched
       to match a taller sibling in the same "row" — a real grid can't do
       that without JS. Two columns max even on very wide screens; the
       bounding-box map reads better wide than the previous 3+ column
       layout allowed. Each card sets break-inside: avoid (CatalogCard.astro)
       so a map is never split across the column break. */
    columns: 2;
    column-gap: 24px;
  }
  @media (max-width: 720px) {
    .catalog__grid { columns: 1; }
  }
  .catalog__empty { margin-top: 40px; }
  .catalog__map-attribution { margin-top: 16px; color: var(--muted); font-size: 0.8125rem; }
</style>

<script>
  // Client-side language + free-text filter (ADR-0007 + ADR-0040 addenda).
  // Language is independent of the page's own nb/en language — plan-content
  // language and site UI language are unrelated axes. Cards with no
  // language set stay visible under every language selection; they aren't
  // a language a visitor picked, they're just unknown. Search matches the
  // data-search blob (name, description, tags, place — see CatalogCard.astro)
  // rather than only visible text, so it also catches a truncated
  // description or place chip.
  const select = document.getElementById(
    'catalog-language-filter',
  ) as HTMLSelectElement | null;
  const search = document.getElementById('catalog-search') as HTMLInputElement | null;

  function applyFilters() {
    const selectedLanguage = select?.value ?? '';
    const query = (search?.value ?? '').trim().toLowerCase();
    document.querySelectorAll<HTMLElement>('.catalog-card').forEach((card) => {
      const cardLanguage = card.dataset.language ?? '';
      const languageMatch =
        cardLanguage === '' || cardLanguage === selectedLanguage || selectedLanguage === '';
      const searchMatch = !query || (card.dataset.search ?? '').includes(query);
      card.style.display = languageMatch && searchMatch ? '' : 'none';
    });
  }

  select?.addEventListener('change', applyFilters);
  search?.addEventListener('input', applyFilters);
</script>
