---
// On-demand (ADR-0044 rendering pattern applied to ADR-0039's reserved
// /catalog route): fetched fresh per request, never build-time-static.
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CatalogCard from '../components/CatalogCard.astro';
import { fetchCatalog } from '../lib/catalog';
import { LANGUAGE_NAMES } from '../lib/languages';
import { t } from '../i18n';

const lang = 'nb';
const c = t(lang);

const apiBase = import.meta.env.PUBLIC_RINGDRILL_API_BASE || 'https://api.ringdrill.app';
const result = await fetchCatalog({ apiBase });
// Static, not derived from the current result set: the filter always
// offers every language the app itself supports (ADR-0007), so it is
// never hidden or missing an option just because nobody has published in
// that language yet. Selecting one still only narrows to items that
// declare it (plus items with no language set, which always stay
// visible) -- an empty result for a given language is a legitimate,
// informative "nobody has published in this language yet", not a sign
// the control is broken.
const languageCodes = Object.keys(LANGUAGE_NAMES);

// Mirrors market-feed.js's own max-age=30 so Cloudflare's edge absorbs
// repeat traffic instead of re-fetching the feed on every visit.
Astro.response.headers.set('Cache-Control', 'public, max-age=30, s-maxage=60');
---
<BaseLayout lang="nb" title={`${c.catalog.title} · RingDrill`} description={c.catalog.lead}>
  <Nav lang="nb" langHref="/en/catalog" />
  <main>
    <section class="section section--band">
      <div class="container">
        <div class="catalog__header">
          <div class="catalog__intro">
            <span class="eyebrow">{c.catalog.eyebrow}</span>
            <h1 class="catalog__title">{c.catalog.title}</h1>
            <p class="lead">{c.catalog.lead}</p>
          </div>
          {result.items.length > 0 && (
            <div class="catalog__toolbar">
              <input
                type="search"
                class="catalog__search"
                id="catalog-search"
                placeholder={c.catalog.searchPlaceholder}
                aria-label={c.catalog.searchPlaceholder}
              />
              <select
                class="catalog__language-filter"
                id="catalog-language-filter"
                aria-label={c.catalog.languageFilterLabel}
              >
                <option value="">{c.catalog.allLanguages}</option>
                {languageCodes.map((code) => (
                  <option value={code}>{LANGUAGE_NAMES[code] ?? code}</option>
                ))}
              </select>
            </div>
          )}
        </div>

        {result.items.length > 0 ? (
          <>
            <ul class="catalog__grid" id="catalog-grid">
              {result.items.map((item) => <CatalogCard item={item} lang="nb" />)}
            </ul>
            {result.items.some((item) => item.mapCenter || item.mapBounds) && (
              <p class="catalog__map-attribution">{c.catalog.mapAttribution}</p>
            )}
          </>
        ) : (
          <div class="catalog__empty prose">
            <p class="lead">{result.failed ? c.catalog.emptyUnavailable : c.catalog.emptyNoPlans}</p>
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer lang="nb" langHref="/en/catalog" />
</BaseLayout>

<style>
  .catalog__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 20px 24px;
  }
  .catalog__intro { flex: 1 1 320px; }
  .catalog__title { margin-top: 12px; }
  .catalog__toolbar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    /* Roughly aligns with the title, not the eyebrow above it. */
    margin-top: 44px;
  }
  .catalog__search {
    font: inherit;
    font-size: 0.9375rem;
    color: var(--heading);
    background: var(--canvas-elev);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    padding: 6px 12px;
    min-width: 220px;
    flex: 1 1 220px;
  }
  .catalog__language-filter {
    font: inherit;
    font-size: 0.9375rem;
    color: var(--heading);
    background: var(--canvas-elev);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    padding: 6px 12px;
    flex: 0 0 auto;
  }
  @media (max-width: 720px) {
    .catalog__toolbar { width: 100%; margin-top: 20px; }
  }
  .catalog__grid {
    list-style: none;
    margin-top: 40px;
    /* Masonry-style fallback for no-JS: a CSS multi-column layout, not a
       grid, so short cards (no map) stack together instead of each being
       stretched to match a taller sibling in the same "row". This is only
       the fallback because column-fill defaults to "balance", which aims
       for equal-height columns rather than filling the first column
       before spilling into the next — the script below reparents cards
       into two explicit, height-balanced <ul>s (.catalog__grid--split)
       once it can measure their real rendered height, which is what
       actually keeps the next card in whichever column is shortest. */
    columns: 2;
    column-gap: 24px;
  }
  @media (max-width: 720px) {
    .catalog__grid { columns: 1; }
  }
  .catalog__grid--split {
    columns: initial;
    display: flex;
    align-items: flex-start;
    gap: 24px;
  }
  .catalog__column {
    flex: 1 1 0;
    min-width: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .catalog__empty { margin-top: 40px; }
  .catalog__map-attribution {
    margin-top: 40px;
    color: var(--muted);
    font-size: 0.8125rem;
    text-align: center;
  }
</style>

<script>
  // Client-side language + free-text filter (ADR-0007 + ADR-0040 addenda).
  // Language is independent of the page's own nb/en language — plan-content
  // language and site UI language are unrelated axes. Cards with no
  // language set stay visible under every language selection; they aren't
  // a language a visitor picked, they're just unknown. Search matches the
  // data-search blob (name, description, tags, place — see CatalogCard.astro)
  // rather than only visible text, so it also catches a truncated
  // description or place chip.
  const select = document.getElementById(
    'catalog-language-filter',
  ) as HTMLSelectElement | null;
  const search = document.getElementById('catalog-search') as HTMLInputElement | null;

  function applyFilters() {
    const selectedLanguage = select?.value ?? '';
    const query = (search?.value ?? '').trim().toLowerCase();
    document.querySelectorAll<HTMLElement>('.catalog-card').forEach((card) => {
      const cardLanguage = card.dataset.language ?? '';
      const languageMatch =
        cardLanguage === '' || cardLanguage === selectedLanguage || selectedLanguage === '';
      const searchMatch = !query || (card.dataset.search ?? '').includes(query);
      card.style.display = languageMatch && searchMatch ? '' : 'none';
    });
  }

  select?.addEventListener('change', applyFilters);
  search?.addEventListener('input', applyFilters);

  // Two-column masonry, done by hand: CSS multi-column's column-fill
  // defaults to "balance" (aim for equal-height columns), not "fill the
  // first column, then spill into the next", so a card can land at the
  // top of column 2 while column 1 still has room — see the CSS comment
  // on .catalog__grid. Captured once, in the server-rendered order, so a
  // resize can always rebuild from the original order rather than
  // whatever order cards happen to be in after a previous reflow.
  const grid = document.getElementById('catalog-grid');
  const cards = grid
    ? Array.from(grid.querySelectorAll<HTMLLIElement>(':scope > .catalog-card'))
    : [];

  function layoutCatalogGrid() {
    if (!grid || cards.length === 0) return;
    const isTwoColumn = window.matchMedia('(min-width: 721px)').matches;

    if (!isTwoColumn) {
      grid.classList.remove('catalog__grid--split');
      grid.replaceChildren(...cards);
      return;
    }

    const columns = [document.createElement('ul'), document.createElement('ul')];
    columns.forEach((col) => col.classList.add('catalog__column'));
    grid.classList.add('catalog__grid--split');
    grid.replaceChildren(...columns);

    // Greedy shortest-column placement, measured as each card lands in
    // its new column (so it reflects that column's real width, not the
    // old layout's), not estimated up front.
    const heights = [0, 0];
    for (const card of cards) {
      const target = heights[0] <= heights[1] ? 0 : 1;
      columns[target].appendChild(card);
      heights[target] += card.getBoundingClientRect().height;
    }
  }

  layoutCatalogGrid();
  window.addEventListener('resize', layoutCatalogGrid);
</script>
