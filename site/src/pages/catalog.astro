---
// On-demand (ADR-0044 rendering pattern applied to ADR-0039's reserved
// /catalog route): fetched fresh per request, never build-time-static.
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CatalogCard from '../components/CatalogCard.astro';
import { fetchCatalog } from '../lib/catalog';
import { distinctLanguageCodes, LANGUAGE_NAMES } from '../lib/languages';
import { t } from '../i18n';

const lang = 'nb';
const c = t(lang);

const apiBase = import.meta.env.PUBLIC_RINGDRILL_API_BASE || 'https://api.ringdrill.app';
const result = await fetchCatalog({ apiBase });
const languageCodes = distinctLanguageCodes(result.items);

// Mirrors market-feed.js's own max-age=30 so Cloudflare's edge absorbs
// repeat traffic instead of re-fetching the feed on every visit.
Astro.response.headers.set('Cache-Control', 'public, max-age=30, s-maxage=60');
---
<BaseLayout lang="nb" title={`${c.catalog.title} · RingDrill`} description={c.catalog.lead}>
  <Nav lang="nb" />
  <main>
    <section class="section section--band">
      <div class="container">
        <span class="eyebrow">{c.catalog.eyebrow}</span>
        <h1 class="catalog__title">{c.catalog.title}</h1>
        <p class="lead">{c.catalog.lead}</p>

        {result.items.length > 0 ? (
          <>
            {languageCodes.length > 1 && (
              <div class="catalog__filter">
                <label class="catalog__filter-label" for="catalog-language-filter">
                  {c.catalog.languageFilterLabel}
                </label>
                <select class="catalog__language-filter" id="catalog-language-filter">
                  <option value="">{c.catalog.allLanguages}</option>
                  {languageCodes.map((code) => (
                    <option value={code}>{LANGUAGE_NAMES[code] ?? code}</option>
                  ))}
                </select>
              </div>
            )}
            <ul class="catalog__grid">
              {result.items.map((item) => <CatalogCard item={item} lang="nb" />)}
            </ul>
            {result.items.some((item) => item.mapCenter || item.mapBounds) && (
              <p class="catalog__map-attribution">{c.catalog.mapAttribution}</p>
            )}
          </>
        ) : (
          <div class="catalog__empty prose">
            <p class="lead">{result.failed ? c.catalog.emptyUnavailable : c.catalog.emptyNoPlans}</p>
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer lang="nb" />
</BaseLayout>

<style>
  .catalog__title { margin-top: 12px; }
  .catalog__grid {
    list-style: none;
    margin-top: 40px;
    display: grid;
    /* Two columns max, even on very wide screens — wider cards read better
       with the bounding-box map. Collapses to one column below 720px. */
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }
  @media (max-width: 720px) {
    .catalog__grid { grid-template-columns: 1fr; }
  }
  .catalog__empty { margin-top: 40px; }
  .catalog__map-attribution { margin-top: 16px; color: var(--muted); font-size: 0.8125rem; }
  .catalog__filter {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 28px;
  }
  .catalog__filter-label {
    color: var(--muted);
    font-size: 0.875rem;
    font-weight: 600;
  }
  .catalog__language-filter {
    font: inherit;
    font-size: 0.9375rem;
    color: var(--heading);
    background: var(--canvas-elev);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    padding: 6px 12px;
  }
</style>

<script>
  // Client-side language filter (ADR-0007 + ADR-0040 addenda). Independent
  // of the page's own nb/en language — plan-content language and site UI
  // language are unrelated axes. Cards with no language set stay visible
  // under every filter selection; they aren't a language a visitor picked,
  // they're just unknown.
  const select = document.getElementById(
    'catalog-language-filter',
  ) as HTMLSelectElement | null;

  if (select) {
    select.addEventListener('change', () => {
      const selected = select.value;
      document.querySelectorAll<HTMLElement>('.catalog-card').forEach((card) => {
        const cardLanguage = card.dataset.language ?? '';
        const visible = cardLanguage === '' || cardLanguage === selected || selected === '';
        card.style.display = visible ? '' : 'none';
      });
    });
  }
</script>
